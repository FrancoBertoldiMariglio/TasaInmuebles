{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Tasainmuebles Design System tokens — W3C Design Tokens Community Group spec (DTCG). Provider-agnostic source of truth. Compile with Style Dictionary, Tokens Studio, or import into Figma/Penpot/any DTCG-aware tool.",
  "$version": "1.0.0",

  "color": {
    "palette": {
      "coral": {
        "50":  { "$value": "#FFF7F5", "$type": "color" },
        "100": { "$value": "#FFE8E8", "$type": "color" },
        "200": { "$value": "#FEE2E2", "$type": "color" },
        "300": { "$value": "#FECACA", "$type": "color" },
        "400": { "$value": "#F87171", "$type": "color" },
        "500": { "$value": "#EF4444", "$type": "color" },
        "600": { "$value": "#DC2626", "$type": "color" }
      },
      "navy": {
        "400": { "$value": "#475569", "$type": "color" },
        "500": { "$value": "#353C4D", "$type": "color" },
        "600": { "$value": "#2A3140", "$type": "color" },
        "700": { "$value": "#1E293B", "$type": "color" },
        "800": { "$value": "#0F172A", "$type": "color" }
      },
      "neutral": {
        "0":   { "$value": "#FFFFFF", "$type": "color" },
        "50":  { "$value": "#F9FAFB", "$type": "color" },
        "100": { "$value": "#F4F5F8", "$type": "color" },
        "150": { "$value": "#EEF0F5", "$type": "color" },
        "200": { "$value": "#EEF0F4", "$type": "color" },
        "250": { "$value": "#E9EBF0", "$type": "color" },
        "300": { "$value": "#E5E7EB", "$type": "color" },
        "350": { "$value": "#D1D5DB", "$type": "color" },
        "400": { "$value": "#9CA3AF", "$type": "color" },
        "500": { "$value": "#6B7280", "$type": "color" },
        "600": { "$value": "#4B5563", "$type": "color" },
        "700": { "$value": "#374151", "$type": "color" },
        "800": { "$value": "#1F2937", "$type": "color" },
        "900": { "$value": "#111827", "$type": "color" }
      },
      "mint": {
        "50":  { "$value": "#F0FDF4", "$type": "color" },
        "100": { "$value": "#D1FAE5", "$type": "color" },
        "200": { "$value": "#6EE7B7", "$type": "color" },
        "400": { "$value": "#34D399", "$type": "color" },
        "500": { "$value": "#10B981", "$type": "color" }
      },
      "mustard": {
        "50":  { "$value": "#FEF3C7", "$type": "color" },
        "300": { "$value": "#FCD34D", "$type": "color" },
        "500": { "$value": "#FBBF24", "$type": "color" },
        "700": { "$value": "#92400E", "$type": "color" }
      },
      "info": {
        "50":  { "$value": "#DBEAFE", "$type": "color" },
        "400": { "$value": "#60A5FA", "$type": "color" },
        "700": { "$value": "#1D4ED8", "$type": "color" }
      }
    },

    "brand": {
      "primary":      { "$value": "{color.palette.coral.400}", "$type": "color" },
      "primaryDeep":  { "$value": "{color.palette.coral.500}", "$type": "color" },
      "primarySoft":  { "$value": "{color.palette.coral.200}", "$type": "color" },
      "primaryBg":    { "$value": "{color.palette.coral.50}",  "$type": "color" }
    },

    "surface": {
      "page":      { "$value": "{color.palette.neutral.100}", "$type": "color" },
      "pageAlt":   { "$value": "{color.palette.neutral.150}", "$type": "color" },
      "card":      { "$value": "{color.palette.neutral.0}",   "$type": "color" },
      "navDark":   { "$value": "{color.palette.navy.600}",    "$type": "color" }
    },

    "border": {
      "default": { "$value": "{color.palette.neutral.300}", "$type": "color" },
      "soft":    { "$value": "{color.palette.neutral.200}", "$type": "color" },
      "dashed":  { "$value": "{color.palette.neutral.350}", "$type": "color" }
    },

    "text": {
      "primary":   { "$value": "{color.palette.neutral.800}", "$type": "color" },
      "secondary": { "$value": "{color.palette.neutral.700}", "$type": "color" },
      "muted":     { "$value": "{color.palette.neutral.400}", "$type": "color" },
      "muted2":    { "$value": "{color.palette.neutral.500}", "$type": "color" },
      "onDark":    { "$value": "{color.palette.neutral.0}",   "$type": "color" }
    },

    "status": {
      "success":     { "$value": "{color.palette.mint.500}",    "$type": "color" },
      "successSoft": { "$value": "{color.palette.mint.100}",    "$type": "color" },
      "warning":     { "$value": "{color.palette.mustard.500}", "$type": "color" },
      "warningSoft": { "$value": "{color.palette.mustard.50}",  "$type": "color" },
      "warningText": { "$value": "{color.palette.mustard.700}", "$type": "color" },
      "info":        { "$value": "{color.palette.info.400}",    "$type": "color" },
      "infoSoft":    { "$value": "{color.palette.info.50}",     "$type": "color" },
      "danger":      { "$value": "{color.palette.coral.500}",   "$type": "color" }
    }
  },

  "spacing": {
    "none": { "$value": "0",  "$type": "dimension" },
    "xs":   { "$value": "4",  "$type": "dimension" },
    "sm":   { "$value": "8",  "$type": "dimension" },
    "md":   { "$value": "12", "$type": "dimension" },
    "lg":   { "$value": "16", "$type": "dimension" },
    "xl":   { "$value": "20", "$type": "dimension" },
    "2xl":  { "$value": "24", "$type": "dimension" },
    "3xl":  { "$value": "32", "$type": "dimension" },
    "4xl":  { "$value": "40", "$type": "dimension" },
    "5xl":  { "$value": "48", "$type": "dimension" },
    "6xl":  { "$value": "64", "$type": "dimension" }
  },

  "radius": {
    "none": { "$value": "0",   "$type": "dimension" },
    "sm":   { "$value": "8",   "$type": "dimension" },
    "md":   { "$value": "12",  "$type": "dimension" },
    "lg":   { "$value": "16",  "$type": "dimension" },
    "xl":   { "$value": "20",  "$type": "dimension" },
    "2xl":  { "$value": "28",  "$type": "dimension" },
    "3xl":  { "$value": "36",  "$type": "dimension" },
    "full": { "$value": "999", "$type": "dimension" }
  },

  "typography": {
    "fontFamily": {
      "ios":     { "$value": "System", "$type": "fontFamily" },
      "android": { "$value": "Roboto", "$type": "fontFamily" }
    },
    "size": {
      "xs":  { "$value": "11", "$type": "dimension" },
      "sm":  { "$value": "12", "$type": "dimension" },
      "base":{ "$value": "13", "$type": "dimension" },
      "md":  { "$value": "14", "$type": "dimension" },
      "lg":  { "$value": "15", "$type": "dimension" },
      "xl":  { "$value": "17", "$type": "dimension" },
      "2xl": { "$value": "20", "$type": "dimension" },
      "3xl": { "$value": "24", "$type": "dimension" },
      "4xl": { "$value": "28", "$type": "dimension" },
      "5xl": { "$value": "32", "$type": "dimension" },
      "6xl": { "$value": "40", "$type": "dimension" }
    },
    "weight": {
      "regular":    { "$value": "400", "$type": "fontWeight" },
      "medium":     { "$value": "500", "$type": "fontWeight" },
      "semibold":   { "$value": "600", "$type": "fontWeight" },
      "bold":       { "$value": "700", "$type": "fontWeight" },
      "extrabold":  { "$value": "800", "$type": "fontWeight" }
    }
  },

  "motion": {
    "duration": {
      "fast":   { "$value": "120ms", "$type": "duration" },
      "base":   { "$value": "200ms", "$type": "duration" },
      "slow":   { "$value": "320ms", "$type": "duration" },
      "slower": { "$value": "480ms", "$type": "duration" }
    },
    "easing": {
      "standard":   { "$value": [0.4, 0.0, 0.2, 1], "$type": "cubicBezier" },
      "decelerate": { "$value": [0.0, 0.0, 0.2, 1], "$type": "cubicBezier" },
      "accelerate": { "$value": [0.4, 0.0, 1.0, 1], "$type": "cubicBezier" },
      "emphasized": { "$value": [0.2, 0.0, 0.0, 1], "$type": "cubicBezier" }
    }
  },

  "zIndex": {
    "base":     { "$value": "0",    "$type": "number" },
    "raised":   { "$value": "1",    "$type": "number" },
    "dropdown": { "$value": "10",   "$type": "number" },
    "sticky":   { "$value": "100",  "$type": "number" },
    "fab":      { "$value": "200",  "$type": "number" },
    "navbar":   { "$value": "300",  "$type": "number" },
    "modal":    { "$value": "1000", "$type": "number" },
    "toast":    { "$value": "2000", "$type": "number" },
    "overlay":  { "$value": "3000", "$type": "number" }
  },

  "opacity": {
    "disabled":   { "$value": "0.4",  "$type": "number" },
    "pressed":    { "$value": "0.85", "$type": "number" },
    "scrim":      { "$value": "0.5",  "$type": "number" },
    "scrimHeavy": { "$value": "0.85", "$type": "number" },
    "glass":      { "$value": "0.78", "$type": "number" }
  }
}
