# ─── Supabase project ──────────────────────────────────────────────────────
# Project ref es la primera parte de tu URL: https://{ref}.supabase.co
SUPABASE_PROJECT_REF=wlrnyisqczvqnectbuhk
SUPABASE_PROJECT_URL=https://wlrnyisqczvqnectbuhk.supabase.co

# Personal Access Token desde https://supabase.com/dashboard/account/tokens
# Necesario para Management API (logs, advisors, projects).
SUPABASE_ACCESS_TOKEN=sbp_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Anon key — Settings → API Keys → "anon" / "public"
SUPABASE_ANON_KEY=eyJhbGciXXX...

# Service role key — Settings → API Keys → "service_role" (SOLO ADMIN, NUNCA COMMIT)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciXXX...

# ─── Postgres direct connection (para psql) ────────────────────────────────
# Dashboard → Settings → Database → Connection string → URI (mode: "Session")
# IMPORTANTE: contiene la password en plain text. NUNCA commitear este .env.
# Formato: postgresql://postgres.{ref}:{pwd}@aws-0-{region}.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.wlrnyisqczvqnectbuhk:PASSWORD@aws-0-us-west-1.pooler.supabase.com:5432/postgres
